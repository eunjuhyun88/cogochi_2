# Supabase
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
DATABASE_URL=postgresql://postgres:password@host:5432/postgres

# External APIs (server-side)
COINALYZE_API_KEY=your_key
GEMINI_API_KEY=your_key
GROQ_API_KEY=your_key

# EVM / Wallet
PUBLIC_EVM_CHAIN_ID=8453
PUBLIC_EVM_RPC_URL=https://base-mainnet.g.alchemy.com/v2/your_key
PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id

# Redis (optional - rate limiting)
RATE_LIMIT_REDIS_REST_URL=
RATE_LIMIT_REDIS_REST_TOKEN=

# CSRF
CSRF_TRUSTED_ORIGINS=https://cogotchi.dev
